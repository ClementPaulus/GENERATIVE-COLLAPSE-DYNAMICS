---
import BaseLayout from '../layouts/BaseLayout.astro';
import RegimeDiagram from '../components/RegimeDiagram.astro';
---

<BaseLayout title="Regime Phase Diagram — GCD">
  <div class="max-w-5xl mx-auto">
    <div class="mb-6">
      <h1 class="text-3xl font-bold text-kernel-100 mb-2">Regime Phase Diagram</h1>
      <p class="text-kernel-400">
        High-resolution 2D phase diagram showing regime classification across the c₁ &times; c₂ plane.
        Three regimes derived from frozen gates: Stable (12.5%), Watch (24.4%), Collapse (63.1%) of Fisher space.
      </p>
    </div>
    <RegimeDiagram />
  </div>
</BaseLayout>
