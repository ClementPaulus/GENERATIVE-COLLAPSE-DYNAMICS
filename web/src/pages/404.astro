---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404 — Not Found" description="Page not found">
  <div class="text-center py-20">
    <h1 class="text-6xl font-bold tracking-tight mb-2 text-kernel-300">404</h1>
    <p class="text-sm font-mono text-kernel-500 mb-8">τ_R = ∞_rec — no return detected</p>
    <p class="text-lg text-kernel-400 mb-8">
      The page you're looking for does not exist in the collapse manifold.
    </p>
    <a href="/" class="text-blue-400 hover:text-blue-300 hover:underline">
      ← Return to domain network
    </a>
  </div>
</BaseLayout>
