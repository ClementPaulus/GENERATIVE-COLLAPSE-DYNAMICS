---
/**
 * Scale Ladder — Cross-Scale Coherence Dynamics
 *
 * Visualizes the oscillation of IC/F across physical scales:
 * quark → hadron → atom. Demonstrates geometric slaughter at
 * confinement and scale inversion at restoration. All computed
 * live through the TypeScript kernel.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Scale Ladder — GCD">
  <div class="max-w-6xl mx-auto">
    <div class="mb-6">
      <h1 class="text-3xl font-bold text-kernel-100 mb-2">Scale Ladder</h1>
      <p class="text-kernel-400 max-w-3xl">
        How coherence propagates across physical scales. Fidelity descends, integrity
        slaughters at phase boundaries, then new degrees of freedom restore what was lost.
        The ladder oscillates between destruction and recovery.
      </p>
      <p class="text-kernel-500 italic text-sm mt-2">
        Ruina fecunda — fruitful ruin. Inversio scalarum — scale inversion.
      </p>
    </div>

    <!-- Scale ladder visual -->
    <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-6 mb-6">
      <h2 class="text-lg font-bold text-kernel-200 mb-4">The Ladder</h2>
      <div class="relative" id="ladder-visual"></div>
    </div>

    <!-- Phase boundary analysis -->
    <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-6 mb-6">
      <h2 class="text-lg font-bold text-kernel-200 mb-4">Phase Boundary Analysis</h2>
      <p class="text-xs text-kernel-500 mb-4">
        Each phase boundary is a seam where channels die and new ones emerge. The kernel
        measures the exact IC/F drop at each transition. Click a boundary to see the computation.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="boundaries"></div>
    </div>

    <!-- Slaughter explorer -->
    <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-6 mb-6">
      <h2 class="text-lg font-bold text-kernel-200 mb-4">Geometric Slaughter Explorer</h2>
      <p class="text-xs text-kernel-500 mb-4">
        Kill 1, 2, or 3 channels and watch IC collapse while F stays healthy. This is the
        mechanism behind every phase boundary on the scale ladder.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
        <div>
          <label class="text-xs text-kernel-400 block mb-1">Total channels</label>
          <input id="n-channels" type="range" min="3" max="12" value="8" class="w-full accent-amber-500" />
          <div class="text-xs text-kernel-500 text-center"><span id="n-label">8</span> channels</div>
        </div>
        <div>
          <label class="text-xs text-kernel-400 block mb-1">Dead channels</label>
          <input id="n-dead" type="range" min="0" max="4" value="1" class="w-full accent-red-500" />
          <div class="text-xs text-kernel-500 text-center"><span id="dead-label">1</span> dead (at ε)</div>
        </div>
        <div>
          <label class="text-xs text-kernel-400 block mb-1">Healthy channel value</label>
          <input id="healthy-val" type="range" min="0.5" max="1" step="0.01" value="0.95" class="w-full accent-green-500" />
          <div class="text-xs text-kernel-500 text-center"><span id="healthy-label">0.95</span></div>
        </div>
      </div>
      <div id="slaughter-results" class="grid grid-cols-2 md:grid-cols-4 gap-3"></div>
      <div class="mt-3">
        <div class="text-xs text-kernel-400 mb-1">IC/F Ratio</div>
        <div class="h-8 bg-kernel-800 rounded-lg overflow-hidden relative">
          <div id="explorer-bar" class="h-full bg-green-500 transition-all duration-300 rounded-lg"></div>
          <div class="absolute inset-0 flex items-center justify-center text-xs font-mono text-white font-bold" id="explorer-bar-label"></div>
        </div>
      </div>
    </div>

    <!-- Domain examples -->
    <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-6">
      <h2 class="text-lg font-bold text-kernel-200 mb-4">Scale Ladder Across Domains</h2>
      <p class="text-xs text-kernel-500 mb-4">
        The scale ladder pattern repeats across all 20 closure domains — not just physics.
        Wherever channels die at a boundary, IC drops; wherever new DOF emerge, IC recovers.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" id="domain-examples"></div>
    </div>
  </div>
</BaseLayout>

<script>
  import { computeKernel, classifyRegime } from '../lib/kernel';
  import { EPSILON } from '../lib/constants';

  // ── Scale ladder data (from particles → atoms) ──
  const scales = [
    {
      name: 'Quarks',
      subtitle: 'Fundamental fermions',
      channels: [0.63, 0.50, 0.33, 1.00, 0.50, 0.00, 0.33, 0.33],
      channelNames: ['mass_log', 'spin', 'charge', 'color', 'isospin', 'lepton', 'baryon', 'generation'],
      color: 'blue',
    },
    {
      name: 'Hadrons',
      subtitle: 'Composite (confinement)',
      channels: [0.55, 0.50, 0.50, EPSILON, 0.50, 0.00, 1.00, 0.33],
      channelNames: ['mass_log', 'spin', 'charge', 'color_confined', 'isospin', 'lepton', 'baryon', 'generation'],
      color: 'red',
    },
    {
      name: 'Nuclei',
      subtitle: 'Nuclear binding',
      channels: [0.60, 0.50, 0.45, EPSILON, 0.40, 0.00, 1.00, 0.50],
      channelNames: ['mass_log', 'spin', 'charge', 'color_confined', 'isospin', 'lepton', 'baryon', 'shell'],
      color: 'amber',
    },
    {
      name: 'Atoms',
      subtitle: 'Electronic restoration',
      channels: [0.65, 0.50, 0.80, 0.75, 0.70, 0.80, 0.85, 0.90],
      channelNames: ['mass', 'spin', 'ionization', 'electronegativity', 'radius', 'affinity', 'melting_pt', 'density'],
      color: 'green',
    },
    {
      name: 'Molecules',
      subtitle: 'Chemical bonding',
      channels: [0.70, 0.60, 0.85, 0.80, 0.75, 0.65, 0.78, 0.82],
      channelNames: ['bond_energy', 'symmetry', 'polarity', 'reactivity', 'stability', 'flexibility', 'dipole', 'orbital_overlap'],
      color: 'cyan',
    },
  ];

  // Compute kernel for all scales
  const scaleResults = scales.map(s => {
    const w = s.channels.map(() => 1 / s.channels.length);
    const result = computeKernel(s.channels, w);
    const regime = classifyRegime(result);
    return { ...s, result, regime, icf: result.F > 0 ? result.IC / result.F : 0 };
  });

  // ── Ladder Visual ──
  const ladderEl = document.getElementById('ladder-visual')!;
  ladderEl.innerHTML = `
    <div class="flex items-end gap-1 justify-center mb-4" style="height: 200px;">
      ${scaleResults.map((s, i) => {
        const pct = Math.max(5, s.icf * 100);
        const barColor = s.icf > 0.7 ? 'bg-green-500' : s.icf > 0.3 ? 'bg-amber-500' : 'bg-red-500';
        return `
          <div class="flex flex-col items-center flex-1 max-w-[120px]">
            <div class="text-xs font-mono text-kernel-400 mb-1">${s.icf.toFixed(3)}</div>
            <div class="w-full ${barColor} rounded-t transition-all" style="height: ${pct * 2}px;"></div>
            <div class="text-xs text-kernel-300 font-bold mt-2">${s.name}</div>
            <div class="text-[10px] text-kernel-500">${s.subtitle}</div>
          </div>
          ${i < scaleResults.length - 1 ? `
            <div class="flex flex-col items-center mx-1 self-center">
              <div class="text-xs text-kernel-600">→</div>
              <div class="text-[10px] text-kernel-600 mt-1">${
                scaleResults[i+1].icf > s.icf ? '↑ restore' : '↓ slaughter'
              }</div>
            </div>
          ` : ''}`;
      }).join('')}
    </div>
    <div class="grid grid-cols-5 gap-2 mt-4">
      ${scaleResults.map(s => {
        const regimeColor = s.regime.regime === 'STABLE' ? 'text-green-400' : s.regime.regime === 'WATCH' ? 'text-amber-400' : 'text-red-400';
        return `
          <div class="bg-kernel-800 rounded p-2 text-center text-xs">
            <div class="text-kernel-500">F</div>
            <div class="font-mono text-kernel-300">${s.result.F.toFixed(3)}</div>
            <div class="text-kernel-500 mt-1">IC</div>
            <div class="font-mono text-kernel-300">${s.result.IC.toFixed(3)}</div>
            <div class="text-kernel-500 mt-1">Δ</div>
            <div class="font-mono text-kernel-300">${s.result.delta.toFixed(3)}</div>
            <div class="${regimeColor} font-bold mt-1">${s.regime.regime}</div>
          </div>`;
      }).join('')}
    </div>`;

  // ── Phase Boundaries ──
  const boundaries = [
    {
      name: 'Confinement',
      from: 0, to: 1,
      explanation: 'Quarks → Hadrons: color channel dies (1.00 → ε). This is geometric slaughter — one dead channel out of 8 kills IC while F drops only moderately.',
      key: 'Color channel → ε',
    },
    {
      name: 'Nuclear Binding',
      from: 1, to: 2,
      explanation: 'Hadrons → Nuclei: channels remain similar. Nuclear binding preserves the confined state but reorganizes isospin. IC stays low because color is still dead.',
      key: 'Color still dead, isospin shifts',
    },
    {
      name: 'Electronic Restoration',
      from: 2, to: 3,
      explanation: 'Nuclei → Atoms: entirely new channels (ionization, electronegativity, radius, affinity) replace confined nuclear channels. IC/F jumps from ~0.01 to ~0.96.',
      key: 'New DOF replace dead channels',
    },
    {
      name: 'Chemical Bonding',
      from: 3, to: 4,
      explanation: 'Atoms → Molecules: bonding creates new channels (polarity, reactivity, orbital overlap). IC remains high because bonding adds structure without killing channels.',
      key: 'Additional coherent channels',
    },
  ];

  document.getElementById('boundaries')!.innerHTML = boundaries.map(b => {
    const from = scaleResults[b.from];
    const to = scaleResults[b.to];
    const icfChange = to.icf - from.icf;
    const isSlaughter = icfChange < -0.1;
    const borderColor = isSlaughter ? 'border-red-700/50' : 'border-green-700/50';
    const arrow = isSlaughter ? '↓' : '↑';
    const arrowColor = isSlaughter ? 'text-red-400' : 'text-green-400';
    return `
      <div class="bg-kernel-800 border ${borderColor} rounded-lg p-4">
        <div class="flex items-center justify-between mb-2">
          <span class="text-sm font-bold text-kernel-200">${b.name}</span>
          <span class="font-mono text-xs ${arrowColor}">${arrow} IC/F: ${from.icf.toFixed(3)} → ${to.icf.toFixed(3)}</span>
        </div>
        <div class="text-xs text-kernel-500 mb-2">${from.name} → ${to.name}</div>
        <p class="text-xs text-kernel-400 mb-2">${b.explanation}</p>
        <div class="text-xs text-kernel-600">Key: ${b.key}</div>
      </div>`;
  }).join('');

  // ── Slaughter Explorer ──
  const nChannelsEl = document.getElementById('n-channels') as HTMLInputElement;
  const nDeadEl = document.getElementById('n-dead') as HTMLInputElement;
  const healthyValEl = document.getElementById('healthy-val') as HTMLInputElement;

  function updateExplorer() {
    const n = parseInt(nChannelsEl.value);
    const dead = Math.min(parseInt(nDeadEl.value), n - 1);
    const healthy = parseFloat(healthyValEl.value);

    document.getElementById('n-label')!.textContent = `${n}`;
    document.getElementById('dead-label')!.textContent = `${dead}`;
    document.getElementById('healthy-label')!.textContent = healthy.toFixed(2);

    nDeadEl.max = `${Math.min(4, n - 1)}`;

    const channels = Array(n - dead).fill(healthy).concat(Array(dead).fill(EPSILON));
    const w = channels.map(() => 1 / channels.length);
    const result = computeKernel(channels, w);
    const regime = classifyRegime(result);
    const icf = result.F > 0 ? result.IC / result.F : 0;

    const regimeColor = regime.regime === 'STABLE' ? 'text-green-400' : regime.regime === 'WATCH' ? 'text-amber-400' : 'text-red-400';

    document.getElementById('slaughter-results')!.innerHTML = [
      { l: 'F (Fidelity)', v: result.F.toFixed(6), c: 'text-green-400' },
      { l: 'IC (Integrity)', v: result.IC.toFixed(6), c: result.IC < 0.3 ? 'text-red-400' : 'text-purple-400' },
      { l: 'Δ (Het. Gap)', v: result.delta.toFixed(6), c: result.delta > 0.3 ? 'text-red-400' : 'text-kernel-300' },
      { l: 'Regime', v: regime.regime + (regime.isCritical ? ' + CRIT' : ''), c: regimeColor },
    ].map(m => `
      <div class="bg-kernel-800 rounded p-2 text-center">
        <div class="text-xs text-kernel-500">${m.l}</div>
        <div class="font-mono text-sm ${m.c}">${m.v}</div>
      </div>
    `).join('');

    const pct = Math.max(0, Math.min(100, icf * 100));
    const bar = document.getElementById('explorer-bar') as HTMLDivElement;
    bar.style.width = `${pct}%`;
    bar.className = `h-full transition-all duration-300 rounded-lg ${pct > 70 ? 'bg-green-500' : pct > 40 ? 'bg-amber-500' : 'bg-red-500'}`;
    document.getElementById('explorer-bar-label')!.textContent = `IC/F = ${icf.toFixed(4)}`;
  }

  [nChannelsEl, nDeadEl, healthyValEl].forEach(el => el.addEventListener('input', updateExplorer));
  updateExplorer();

  // ── Domain Examples ──
  const domainExamples = [
    {
      name: 'Particle Physics',
      ladder: 'quarks → hadrons → atoms',
      slaughter: 'Color confinement kills IC (98% drop)',
      recovery: 'Electronic DOF restore IC at atomic scale',
      icon: '⚛️',
    },
    {
      name: 'Finance',
      ladder: 'portfolios → crises → recoveries',
      slaughter: 'Subprime collapse → one dead sector channel',
      recovery: 'Diversification into new asset classes',
      icon: '📈',
    },
    {
      name: 'Consciousness',
      ladder: 'waking → sleep stages → dream',
      slaughter: 'Deep sleep: executive function → ε',
      recovery: 'REM restores coherence with new processing modes',
      icon: '🧠',
    },
    {
      name: 'Semiotics',
      ladder: 'formal → pidgin → creole',
      slaughter: 'Language contact kills grammatical channels',
      recovery: 'Creolization introduces new grammatical structure',
      icon: '📜',
    },
    {
      name: 'History',
      ladder: 'empire → collapse → renaissance',
      slaughter: 'Fall of Rome: institutional channels die',
      recovery: 'Renaissance restores with new cultural DOF',
      icon: '🏛️',
    },
    {
      name: 'Evolution',
      ladder: 'species → extinction → radiation',
      slaughter: 'Mass extinction: diversity channels → ε',
      recovery: 'Adaptive radiation fills new niches',
      icon: '🧬',
    },
  ];

  document.getElementById('domain-examples')!.innerHTML = domainExamples.map(d => `
    <div class="bg-kernel-800 border border-kernel-700 rounded-lg p-4 hover:border-kernel-500 transition">
      <div class="flex items-center gap-2 mb-2">
        <span class="text-xl">${d.icon}</span>
        <span class="text-sm font-bold text-kernel-200">${d.name}</span>
      </div>
      <div class="text-xs text-kernel-400 mb-1">
        <span class="text-kernel-500">Ladder:</span> ${d.ladder}
      </div>
      <div class="text-xs text-red-400/80 mb-1">
        <span class="text-kernel-500">Slaughter:</span> ${d.slaughter}
      </div>
      <div class="text-xs text-green-400/80">
        <span class="text-kernel-500">Recovery:</span> ${d.recovery}
      </div>
    </div>
  `).join('');
</script>
