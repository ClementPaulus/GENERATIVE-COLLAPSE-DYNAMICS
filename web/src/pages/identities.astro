---
/**
 * Identity Network — 44 Structural Identities & Their Connections
 *
 * Visualizes the 44 identities derived from Axiom-0 across 4 series
 * (E:8, B:12, D:8, N:16) and their 6 connection clusters. Each identity
 * is verified by live kernel computation.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="Identity Network — GCD">
  <div class="max-w-6xl mx-auto">
    <div class="mb-6">
      <h1 class="text-3xl font-bold text-kernel-100 mb-2">Identity Network</h1>
      <p class="text-kernel-400 max-w-3xl">
        44 structural identities derived from Axiom-0 and verified to machine precision.
        They fall into four series and form six connection clusters. Every identity is
        re-derivable through computation — the numbers are the understanding.
      </p>
      <p class="text-kernel-500 italic text-sm mt-2">
        Numeri sunt intellectus. — The numbers are the understanding.
      </p>
    </div>

    <!-- Series overview -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
      <button data-series="all" class="series-btn bg-kernel-700 text-kernel-200 px-4 py-3 rounded-lg text-center transition">
        <div class="text-2xl font-bold">44</div>
        <div class="text-xs">All Identities</div>
      </button>
      <button data-series="E" class="series-btn bg-kernel-800 text-kernel-400 px-4 py-3 rounded-lg text-center hover:bg-kernel-700 transition">
        <div class="text-2xl font-bold text-blue-400">8</div>
        <div class="text-xs">E — Equator</div>
      </button>
      <button data-series="B" class="series-btn bg-kernel-800 text-kernel-400 px-4 py-3 rounded-lg text-center hover:bg-kernel-700 transition">
        <div class="text-2xl font-bold text-green-400">12</div>
        <div class="text-xs">B — Bound</div>
      </button>
      <button data-series="D" class="series-btn bg-kernel-800 text-kernel-400 px-4 py-3 rounded-lg text-center hover:bg-kernel-700 transition">
        <div class="text-2xl font-bold text-amber-400">8</div>
        <div class="text-xs">D — Duality</div>
      </button>
    </div>

    <!-- Identity list -->
    <div id="identity-list" class="space-y-3 mb-8"></div>

    <!-- Connection clusters -->
    <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-6 mb-6">
      <h2 class="text-lg font-bold text-kernel-200 mb-4">6 Connection Clusters</h2>
      <p class="text-xs text-kernel-500 mb-4">
        The 44 identities form a connected network. These six clusters reveal the deep
        structure — each identity participates in at least one cluster.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" id="clusters"></div>
    </div>

    <!-- Live verification -->
    <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-6">
      <h2 class="text-lg font-bold text-kernel-200 mb-3">Live Verification</h2>
      <p class="text-xs text-kernel-500 mb-4">
        Verify the core identities by sweeping channel values. The kernel runs 1000 random
        configurations and checks every identity to machine precision.
      </p>
      <button id="run-sweep" class="bg-amber-700 hover:bg-amber-600 text-white px-4 py-2 rounded text-sm transition">
        Run 1000-Point Sweep
      </button>
      <div id="sweep-results" class="mt-4"></div>
    </div>
  </div>
</BaseLayout>

<script>
  import { computeKernel, classifyRegime, verifyIdentities, bernoulliEntropy } from '../lib/kernel';
  import { EPSILON, C_STAR, C_TRAP, OMEGA_TRAP } from '../lib/constants';

  // ── Identity data ──
  // Key identities from the 44 structural identities (E, B, D, N series)
  const identities = [
    // E series — Equator / Exact identities
    { id: 'E1', series: 'E', name: 'Duality Identity', formula: 'F + ω = 1', cluster: 'Equator Web', description: 'Exact to 0.0e+00 across all traces. The complementum perfectum.' },
    { id: 'E2', series: 'E', name: 'Log-Integrity Relation', formula: 'IC = exp(κ)', cluster: 'Dual Bounds', description: 'Links multiplicative and additive coherence. Exact by construction.' },
    { id: 'E3', series: 'E', name: 'Integrity Bound', formula: 'IC ≤ F', cluster: 'Dual Bounds', description: 'Solvability condition: c₁,₂ = F ± √(F²−IC²). Not AM-GM — strictly more general.' },
    { id: 'E4', series: 'E', name: 'Equator Fixed Point', formula: 'S(½) + κ(½) = 0', cluster: 'Equator Web', description: 'Perfect cancellation at c = ½. Four-way convergence point.' },
    { id: 'E5', series: 'E', name: 'Fisher Metric Unity', formula: 'g_F(θ) = 1', cluster: 'Equator Web', description: 'The Bernoulli manifold is flat in Fisher coordinates. All structure is from embedding.' },
    { id: 'E6', series: 'E', name: 'One Function', formula: 'f(θ) = 2cos²θ·ln(tan θ)', cluster: 'Equator Web', description: 'S and κ are projections of one function. Verified to < 10⁻¹⁶.' },
    { id: 'E7', series: 'E', name: 'Spectral Integral', formula: '∫g_F·S dc = π²/3 = 2ζ(2)', cluster: 'Spectral Family', description: 'The Fisher-weighted entropy integral equals twice the Riemann zeta at 2.' },
    { id: 'E8', series: 'E', name: 'Seam Associativity', formula: '(A ∘ B) ∘ C = A ∘ (B ∘ C)', cluster: 'Composition Algebra', description: 'Seam composition is an exact monoid. Error: 5.55e-17.' },

    // B series — Bound & Composition
    { id: 'B1', series: 'B', name: 'Entropy Upper Bound', formula: 'S ≤ h(F)', cluster: 'Dual Bounds', description: 'Entropy bounded above by a function of fidelity. Kernel sandwiched.' },
    { id: 'B2', series: 'B', name: 'IC Geometric Composition', formula: 'IC₁₂ = √(IC₁·IC₂)', cluster: 'Composition Algebra', description: 'IC composes geometrically across seams.' },
    { id: 'B3', series: 'B', name: 'F Arithmetic Composition', formula: 'F₁₂ = (F₁+F₂)/2', cluster: 'Composition Algebra', description: 'F composes arithmetically across seams.' },
    { id: 'B4', series: 'B', name: 'Gap Composition Law', formula: 'Δ₁₂ = (Δ₁+Δ₂)/2 + correction', cluster: 'Composition Algebra', description: 'Het. gap has Hellinger-like composition law.' },
    { id: 'B5', series: 'B', name: 'Perturbation Chain Start', formula: 'IC ≈ F − C²/(8F²)', cluster: 'Perturbation Chain', description: 'First-order correction to IC near the homogeneous limit. Always negative.' },
    { id: 'B6', series: 'B', name: 'Cardano Root', formula: 'x³ + x − 1 = 0', cluster: 'Fixed-Point Triangle', description: 'p = 3 is unique: ω_trap is the real root of this cubic.' },
    { id: 'B7', series: 'B', name: 'Equator Quintuple Point', formula: 'c = ½ is 5-way fixed', cluster: 'Equator Web', description: 'Maximum S, κ = ln(½), S+κ = 0, C_homogeneous, and Fisher symmetry.' },
    { id: 'B8', series: 'B', name: 'Logistic Fixed Point', formula: 'c* = 0.7822', cluster: 'Fixed-Point Triangle', description: 'Self-dual fixed point maximizing S + κ per channel.' },
    { id: 'B9', series: 'B', name: 'Reflection Formula', formula: 'f(c) + f(1−c) = 0', cluster: 'Equator Web', description: 'The combined function S+κ is antisymmetric about c = ½.' },
    { id: 'B10', series: 'B', name: 'Fisher Space Partition', formula: '63.1% + 24.4% + 12.5% = 100%', cluster: 'Fixed-Point Triangle', description: 'Collapse/Watch/Stable partition of the Fisher manifold.' },
    { id: 'B11', series: 'B', name: 'Super-Exponential Convergence', formula: 'IC → F faster than e^(-n)', cluster: 'Perturbation Chain', description: 'IC approaches F super-exponentially fast as channels homogenize. Gap shrinks 28.5×.' },
    { id: 'B12', series: 'B', name: 'Low-Rank Closures', formula: '5 diagnostics → 4 effective dims', cluster: 'Composition Algebra', description: 'The closure algebra is low-rank — PCA confirms half the DOF are constrained.' },

    // D series — Duality & Deep structure
    { id: 'D1', series: 'D', name: 'Solvability Equation', formula: 'c₁,₂ = F ± √(F²−IC²)', cluster: 'Dual Bounds', description: 'Recover trace from kernel. Requires IC ≤ F.' },
    { id: 'D2', series: 'D', name: 'Rank Classification', formula: 'Rank-1 ⊂ Rank-2 ⊂ Rank-3', cluster: 'Perturbation Chain', description: 'Structural dimensionality: 1 DOF → 2 DOF → 3 DOF.' },
    { id: 'D3', series: 'D', name: 'Homogeneous Fast Path', formula: 'All cᵢ = c₀ ⟹ IC = F', cluster: 'Equator Web', description: 'Rank-1 traces have zero het. gap. The only case where IC touches F.' },
    { id: 'D4', series: 'D', name: 'Confinement Cliff', formula: 'IC drops 98% at boundary', cluster: 'Fixed-Point Triangle', description: 'Quark→hadron: IC drops 2 orders of magnitude. Dead color channel.' },
    { id: 'D5', series: 'D', name: 'Scale Inversion', formula: 'Atom IC/F ≈ 0.96 after cliff', cluster: 'Fixed-Point Triangle', description: 'New DOF at atomic scale restore what confinement destroyed.' },
    { id: 'D6', series: 'D', name: 'Het. Gap Invariant', formula: 'Δ invariant under identical composition', cluster: 'Composition Algebra', description: 'Composing identical subsystems preserves the het. gap.' },
    { id: 'D7', series: 'D', name: 'Entropy-Curvature Correlation', formula: 'corr(C,S) → −1 as n → ∞', cluster: 'Perturbation Chain', description: 'Entropy becomes determined by curvature at high channel count.' },
    { id: 'D8', series: 'D', name: 'Budget Conservation', formula: 'Δκ = R·τ_R − (D_ω + D_C)', cluster: 'Composition Algebra', description: 'The seam budget must balance: credits equal debits plus residual.' },
  ];

  // ── Connection clusters ──
  const clusters = [
    {
      name: 'Equator Web',
      color: 'blue',
      members: ['E1', 'E4', 'E5', 'E6', 'B7', 'B9', 'D3'],
      description: 'c = ½ is a quintuple fixed point — maximum entropy, symmetric Fisher metric, S+κ cancellation, and the one-function identity all converge here.',
    },
    {
      name: 'Dual Bounds',
      color: 'green',
      members: ['E2', 'E3', 'B1', 'D1'],
      description: 'The kernel is sandwiched: IC ≤ F from below, S ≤ h(F) from above. Together they constrain the kernel\'s output space.',
    },
    {
      name: 'Perturbation Chain',
      color: 'purple',
      members: ['B5', 'B11', 'D2', 'D7'],
      description: 'A6→B3→A2: the integrity bound follows from the kernel\'s own Taylor structure. The correction −C²/(8F²) is always negative.',
    },
    {
      name: 'Composition Algebra',
      color: 'amber',
      members: ['E8', 'B2', 'B3', 'B4', 'B12', 'D6', 'D8'],
      description: 'IC composes geometrically, F composes arithmetically, the het. gap has a Hellinger-like correction. Seam composition is an exact monoid.',
    },
    {
      name: 'Fixed-Point Triangle',
      color: 'red',
      members: ['B6', 'B8', 'B10', 'D4', 'D5'],
      description: 'Three special points (c=½, c*=0.7822, c_trap=0.3178) form the manifold skeleton. Connected by the reflection formula.',
    },
    {
      name: 'Spectral Family',
      color: 'cyan',
      members: ['E7'],
      description: 'All polynomial moments of f=S+κ have closed forms with harmonic numbers. ∫g_F·S dc = π²/3 = 2ζ(2).',
    },
  ];

  const seriesColors: Record<string, string> = {
    E: 'border-blue-700/50 bg-blue-900/10',
    B: 'border-green-700/50 bg-green-900/10',
    D: 'border-amber-700/50 bg-amber-900/10',
  };

  const seriesTextColors: Record<string, string> = {
    E: 'text-blue-400',
    B: 'text-green-400',
    D: 'text-amber-400',
  };

  let activeSeries = 'all';

  function renderIdentities() {
    const filtered = activeSeries === 'all' ? identities : identities.filter(i => i.series === activeSeries);
    const list = document.getElementById('identity-list')!;
    list.innerHTML = filtered.map(id => `
      <div class="bg-kernel-900 border ${seriesColors[id.series]} rounded-lg p-4 hover:brightness-110 transition">
        <div class="flex items-start justify-between mb-2">
          <div class="flex items-center gap-3">
            <span class="font-mono text-xs ${seriesTextColors[id.series]} bg-kernel-800 px-2 py-0.5 rounded">${id.id}</span>
            <span class="text-sm font-bold text-kernel-200">${id.name}</span>
          </div>
          <span class="text-xs text-kernel-500 bg-kernel-800 px-2 py-0.5 rounded">${id.cluster}</span>
        </div>
        <div class="bg-kernel-800 rounded px-3 py-2 text-sm font-mono text-amber-400 mb-2">${id.formula}</div>
        <p class="text-xs text-kernel-400">${id.description}</p>
      </div>
    `).join('');
  }

  // Series filter buttons
  document.querySelectorAll('.series-btn').forEach(btn =>
    btn.addEventListener('click', () => {
      activeSeries = (btn as HTMLElement).dataset.series!;
      document.querySelectorAll('.series-btn').forEach(b => {
        (b as HTMLElement).className = 'series-btn bg-kernel-800 text-kernel-400 px-4 py-3 rounded-lg text-center hover:bg-kernel-700 transition';
      });
      (btn as HTMLElement).className = 'series-btn bg-kernel-700 text-kernel-200 px-4 py-3 rounded-lg text-center transition';
      renderIdentities();
    })
  );

  // ── Clusters ──
  const clusterColors: Record<string, { bg: string; border: string; text: string }> = {
    blue: { bg: 'bg-blue-900/20', border: 'border-blue-700/50', text: 'text-blue-400' },
    green: { bg: 'bg-green-900/20', border: 'border-green-700/50', text: 'text-green-400' },
    purple: { bg: 'bg-purple-900/20', border: 'border-purple-700/50', text: 'text-purple-400' },
    amber: { bg: 'bg-amber-900/20', border: 'border-amber-700/50', text: 'text-amber-400' },
    red: { bg: 'bg-red-900/20', border: 'border-red-700/50', text: 'text-red-400' },
    cyan: { bg: 'bg-cyan-900/20', border: 'border-cyan-700/50', text: 'text-cyan-400' },
  };

  document.getElementById('clusters')!.innerHTML = clusters.map(cl => {
    const cc = clusterColors[cl.color];
    return `
      <div class="${cc.bg} border ${cc.border} rounded-lg p-4">
        <div class="${cc.text} font-bold text-sm mb-2">${cl.name}</div>
        <p class="text-xs text-kernel-400 mb-2">${cl.description}</p>
        <div class="flex flex-wrap gap-1">
          ${cl.members.map(m => `<span class="text-xs font-mono ${cc.text} bg-kernel-800 px-1.5 py-0.5 rounded">${m}</span>`).join('')}
        </div>
      </div>`;
  }).join('');

  // ── 1000-point sweep ──
  const runBtn = document.getElementById('run-sweep')!;
  const sweepResults = document.getElementById('sweep-results')!;

  runBtn.addEventListener('click', () => {
    runBtn.textContent = 'Running...';
    (runBtn as HTMLButtonElement).disabled = true;

    // Use setTimeout to yield for UI update
    setTimeout(() => {
      const N = 1000;
      let dualityMax = 0;
      let boundViolations = 0;
      let logIntegrityMax = 0;
      let sweepCount = 0;

      for (let i = 0; i < N; i++) {
        // Random channel count 2-12, random values
        const nCh = 2 + Math.floor(Math.random() * 11);
        const channels = Array.from({ length: nCh }, () => Math.random() * 0.999 + 0.001);
        const w = channels.map(() => 1 / channels.length);
        const result = computeKernel(channels, w);
        sweepCount++;

        // Duality: F + ω = 1
        const dualRes = Math.abs(result.F + result.omega - 1);
        if (dualRes > dualityMax) dualityMax = dualRes;

        // Bound: IC ≤ F
        if (result.IC > result.F + 1e-12) boundViolations++;

        // Log-integrity: IC = exp(κ)
        const liRes = Math.abs(result.IC - Math.exp(result.kappa));
        if (liRes > logIntegrityMax) logIntegrityMax = liRes;
      }

      const allPass = dualityMax < 1e-10 && boundViolations === 0 && logIntegrityMax < 1e-10;

      sweepResults.innerHTML = `
        <div class="grid grid-cols-1 md:grid-cols-3 gap-3 mb-3">
          <div class="bg-kernel-800 rounded p-3 text-center">
            <div class="text-xs text-kernel-500">F + ω = 1 max residual</div>
            <div class="font-mono text-sm ${dualityMax < 1e-10 ? 'text-green-400' : 'text-red-400'}">${dualityMax.toExponential(2)}</div>
          </div>
          <div class="bg-kernel-800 rounded p-3 text-center">
            <div class="text-xs text-kernel-500">IC ≤ F violations</div>
            <div class="font-mono text-sm ${boundViolations === 0 ? 'text-green-400' : 'text-red-400'}">${boundViolations} / ${N}</div>
          </div>
          <div class="bg-kernel-800 rounded p-3 text-center">
            <div class="text-xs text-kernel-500">IC = exp(κ) max residual</div>
            <div class="font-mono text-sm ${logIntegrityMax < 1e-10 ? 'text-green-400' : 'text-red-400'}">${logIntegrityMax.toExponential(2)}</div>
          </div>
        </div>
        <div class="text-center p-2 rounded ${allPass ? 'bg-green-900/30 border border-green-700/50' : 'bg-red-900/30 border border-red-700/50'}">
          <span class="${allPass ? 'text-green-400' : 'text-red-400'} font-bold text-sm">
            ${allPass ? '✓ ALL IDENTITIES VERIFIED' : '✗ IDENTITY VIOLATION DETECTED'} — ${sweepCount} configurations tested
          </span>
        </div>`;

      runBtn.textContent = 'Run 1000-Point Sweep';
      (runBtn as HTMLButtonElement).disabled = false;
    }, 50);
  });

  renderIdentities();
</script>
