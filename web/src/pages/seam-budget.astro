---
/**
 * Seam Budget Explorer — Interactive Γ(ω), D_C, Δκ diagnostic
 *
 * Explores the three cost functions that govern seam closure:
 * - Γ(ω) = ω^p / (1 − ω + ε) — drift cost (pole at ω=1)
 * - D_C = α · C — curvature cost
 * - Δκ = R · τ_R − (D_ω + D_C) — the budget that must reconcile
 *
 * All computed live through the TypeScript kernel.
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Seam Budget Explorer — GCD">
  <div class="max-w-6xl mx-auto">
    <div class="mb-6">
      <h1 class="text-3xl font-bold text-kernel-100 mb-2">Seam Budget Explorer</h1>
      <p class="text-kernel-400 max-w-3xl">
        The seam budget Δκ = R·τ_R − (D_ω + D_C) must reconcile to |residual| ≤ tol_seam.
        Explore the cost functions, credit mechanisms, and the pole structure that governs
        the boundary between return and permanent detention.
      </p>
      <p class="text-kernel-500 italic text-sm mt-2">
        Si τ_R = ∞_rec, nulla fides datur. — If return time is infinite, no credit is given.
      </p>
    </div>

    <!-- Budget controls -->
    <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-6 mb-6">
      <h2 class="text-lg font-bold text-kernel-200 mb-4">Budget Parameters</h2>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-4">
        <div>
          <label class="text-xs text-kernel-400 block mb-1">ω (Drift)</label>
          <input id="omega" type="range" min="0" max="0.99" step="0.001" value="0.15" class="w-full accent-red-500" />
          <div class="text-xs font-mono text-kernel-500 text-center" id="omega-label">0.150</div>
        </div>
        <div>
          <label class="text-xs text-kernel-400 block mb-1">C (Curvature)</label>
          <input id="curvature" type="range" min="0" max="1" step="0.01" value="0.10" class="w-full accent-amber-500" />
          <div class="text-xs font-mono text-kernel-500 text-center" id="curvature-label">0.10</div>
        </div>
        <div>
          <label class="text-xs text-kernel-400 block mb-1">R (Return credit)</label>
          <input id="R" type="range" min="0" max="2" step="0.01" value="0.50" class="w-full accent-green-500" />
          <div class="text-xs font-mono text-kernel-500 text-center" id="R-label">0.50</div>
        </div>
        <div>
          <label class="text-xs text-kernel-400 block mb-1">τ_R (Return time)</label>
          <input id="tauR" type="range" min="1" max="50" step="1" value="5" class="w-full accent-blue-500" />
          <div class="text-xs font-mono text-kernel-500 text-center" id="tauR-label">5</div>
          <label class="text-[10px] text-kernel-600 block mt-1">
            <input type="checkbox" id="inf-rec" class="mr-1" /> ∞_rec (no return)
          </label>
        </div>
        <div>
          <label class="text-xs text-kernel-400 block mb-1">κ_ledger</label>
          <input id="kappa-ledger" type="range" min="-2" max="2" step="0.01" value="0" class="w-full accent-purple-500" />
          <div class="text-xs font-mono text-kernel-500 text-center" id="kappa-label">0.00</div>
        </div>
      </div>

      <!-- Preset buttons -->
      <div class="flex flex-wrap gap-2 mt-4">
        <button data-preset="stable" class="px-3 py-1 text-xs bg-green-900/50 text-green-400 rounded border border-green-800 hover:bg-green-800/50">Stable return</button>
        <button data-preset="watch" class="px-3 py-1 text-xs bg-amber-900/50 text-amber-400 rounded border border-amber-800 hover:bg-amber-800/50">Watch regime</button>
        <button data-preset="collapse" class="px-3 py-1 text-xs bg-red-900/50 text-red-400 rounded border border-red-800 hover:bg-red-800/50">Deep collapse</button>
        <button data-preset="pole" class="px-3 py-1 text-xs bg-purple-900/50 text-purple-400 rounded border border-purple-800 hover:bg-purple-800/50">Near pole (ω→1)</button>
        <button data-preset="gesture" class="px-3 py-1 text-xs bg-kernel-800 text-kernel-400 rounded border border-kernel-600 hover:bg-kernel-700">Gesture (∞_rec)</button>
      </div>
    </div>

    <!-- Budget results -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6" id="budget-results"></div>

    <!-- Budget visualization -->
    <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-6 mb-6">
      <h2 class="text-lg font-bold text-kernel-200 mb-4">Budget Breakdown</h2>
      <div id="budget-bars"></div>
      <div class="mt-4 flex items-center gap-2" id="verdict-line"></div>
    </div>

    <!-- Γ(ω) curve -->
    <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-6 mb-6">
      <h2 class="text-lg font-bold text-kernel-200 mb-4">Drift Cost Curve Γ(ω)</h2>
      <p class="text-xs text-kernel-500 mb-4">
        Γ(ω) = ω³ / (1 − ω + ε). Monotone increasing with a pole at ω = 1.
        The frozen exponent p = 3 yields ω_trap = 0.6823 (Cardano root of x³ + x − 1 = 0).
      </p>
      <div class="relative bg-kernel-800 rounded-lg overflow-hidden" style="height: 240px;" id="gamma-chart"></div>
      <div class="flex justify-between text-[10px] text-kernel-600 mt-1">
        <span>ω = 0</span>
        <span>ω = 0.5</span>
        <span>ω = 1</span>
      </div>
    </div>

    <!-- Cost decomposition across ω sweep -->
    <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-6">
      <h2 class="text-lg font-bold text-kernel-200 mb-4">Cost Anatomy</h2>
      <p class="text-xs text-kernel-500 mb-4">
        Three cost functions govern the seam. The budget Δκ is their net balance.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4" id="cost-anatomy"></div>
    </div>
  </div>
</BaseLayout>

<script>
  import { gammaOmega, costCurvature, computeSeamBudget, classifyRegime, computeKernel } from '../lib/kernel';
  import { EPSILON, P_EXPONENT, ALPHA, TOL_SEAM, C_TRAP, OMEGA_TRAP } from '../lib/constants';

  const els = {
    omega: document.getElementById('omega') as HTMLInputElement,
    curvature: document.getElementById('curvature') as HTMLInputElement,
    R: document.getElementById('R') as HTMLInputElement,
    tauR: document.getElementById('tauR') as HTMLInputElement,
    infRec: document.getElementById('inf-rec') as HTMLInputElement,
    kappaLedger: document.getElementById('kappa-ledger') as HTMLInputElement,
  };

  const presets: Record<string, { omega: number; C: number; R: number; tauR: number; inf: boolean; kappa: number }> = {
    stable:   { omega: 0.02,  C: 0.08, R: 0.80, tauR: 3,  inf: false, kappa: 0 },
    watch:    { omega: 0.15,  C: 0.20, R: 0.50, tauR: 8,  inf: false, kappa: 0 },
    collapse: { omega: 0.55,  C: 0.45, R: 0.30, tauR: 20, inf: false, kappa: 0 },
    pole:     { omega: 0.97,  C: 0.60, R: 0.10, tauR: 50, inf: false, kappa: 0 },
    gesture:  { omega: 0.40,  C: 0.30, R: 0.00, tauR: 1,  inf: true,  kappa: 0 },
  };

  function setPreset(name: string) {
    const p = presets[name];
    if (!p) return;
    els.omega.value = `${p.omega}`;
    els.curvature.value = `${p.C}`;
    els.R.value = `${p.R}`;
    els.tauR.value = `${p.tauR}`;
    els.infRec.checked = p.inf;
    els.kappaLedger.value = `${p.kappa}`;
    update();
  }

  document.querySelectorAll('[data-preset]').forEach(btn => {
    btn.addEventListener('click', () => {
      setPreset((btn as HTMLElement).dataset.preset!);
    });
  });

  function update() {
    const omega = parseFloat(els.omega.value);
    const C = parseFloat(els.curvature.value);
    const R = parseFloat(els.R.value);
    const tauR = els.infRec.checked ? Infinity : parseInt(els.tauR.value);
    const kappaLedger = parseFloat(els.kappaLedger.value);

    // labels
    document.getElementById('omega-label')!.textContent = omega.toFixed(3);
    document.getElementById('curvature-label')!.textContent = C.toFixed(2);
    document.getElementById('R-label')!.textContent = R.toFixed(2);
    document.getElementById('tauR-label')!.textContent = els.infRec.checked ? '∞_rec' : `${tauR}`;
    document.getElementById('kappa-label')!.textContent = kappaLedger.toFixed(2);

    const budget = computeSeamBudget(omega, C, R, tauR, kappaLedger);
    const gamma = budget.gamma;
    const D_omega = budget.D_omega;
    const D_C = budget.D_C;
    const credit = els.infRec.checked ? 0 : R * tauR;

    // Results cards
    const metrics = [
      { l: 'Γ(ω)', v: gamma > 1000 ? gamma.toExponential(2) : gamma.toFixed(4), c: 'text-red-400' },
      { l: 'D_C = α·C', v: D_C.toFixed(4), c: 'text-amber-400' },
      { l: 'Credit R·τ_R', v: els.infRec.checked ? '0 (∞_rec)' : credit.toFixed(4), c: credit > 0 ? 'text-green-400' : 'text-kernel-500' },
      { l: 'Δκ (budget)', v: budget.deltaKappa > 1000 ? budget.deltaKappa.toExponential(2) : budget.deltaKappa.toFixed(4), c: budget.pass ? 'text-green-400' : 'text-red-400' },
    ];

    document.getElementById('budget-results')!.innerHTML = metrics.map(m => `
      <div class="bg-kernel-900 border border-kernel-700 rounded-lg p-3 text-center">
        <div class="text-xs text-kernel-500">${m.l}</div>
        <div class="font-mono text-lg ${m.c}">${m.v}</div>
      </div>
    `).join('');

    // Budget bar visualization
    const debit = D_omega + D_C;
    const maxScale = Math.max(debit, credit, 0.01);

    document.getElementById('budget-bars')!.innerHTML = `
      <div class="space-y-2">
        <div>
          <div class="flex justify-between text-xs text-kernel-500 mb-1">
            <span>Debits: D_ω + D_C = ${debit.toFixed(4)}</span>
            <span class="text-red-400">Cost</span>
          </div>
          <div class="h-6 bg-kernel-800 rounded overflow-hidden flex">
            <div class="h-full bg-red-600" style="width: ${Math.min(100, (D_omega / maxScale) * 100)}%;"
                 title="Γ(ω) = ${D_omega.toFixed(4)}"></div>
            <div class="h-full bg-amber-600" style="width: ${Math.min(100, (D_C / maxScale) * 100)}%;"
                 title="D_C = ${D_C.toFixed(4)}"></div>
          </div>
          <div class="flex text-[10px] text-kernel-600 mt-0.5 gap-3">
            <span class="flex items-center gap-1"><span class="w-2 h-2 bg-red-600 rounded-sm inline-block"></span> Γ(ω)</span>
            <span class="flex items-center gap-1"><span class="w-2 h-2 bg-amber-600 rounded-sm inline-block"></span> D_C</span>
          </div>
        </div>
        <div>
          <div class="flex justify-between text-xs text-kernel-500 mb-1">
            <span>Credit: R·τ_R = ${els.infRec.checked ? '0' : credit.toFixed(4)}</span>
            <span class="text-green-400">Return</span>
          </div>
          <div class="h-6 bg-kernel-800 rounded overflow-hidden">
            <div class="h-full bg-green-600" style="width: ${els.infRec.checked ? 0 : Math.min(100, (credit / maxScale) * 100)}%;"></div>
          </div>
        </div>
      </div>`;

    // Verdict
    const pass = budget.pass;
    const absRes = Math.abs(budget.residual);
    document.getElementById('verdict-line')!.innerHTML = `
      <span class="px-3 py-1 rounded text-sm font-bold ${pass ? 'bg-green-900/60 text-green-400 border border-green-700' : 'bg-red-900/60 text-red-400 border border-red-700'}">
        ${pass ? 'SEAM PASS' : 'SEAM FAIL'}
      </span>
      <span class="text-xs text-kernel-500">|residual| = ${absRes > 1000 ? absRes.toExponential(2) : absRes.toFixed(6)} ${pass ? '≤' : '>'} tol = ${TOL_SEAM}</span>
      ${els.infRec.checked ? '<span class="text-xs text-kernel-600 italic ml-2">(Gesture — τ_R = ∞_rec, no credit)</span>' : ''}`;

    // Gamma chart
    renderGammaChart(omega);
  }

  function renderGammaChart(currentOmega: number) {
    const chart = document.getElementById('gamma-chart')!;
    const steps = 200;
    const maxDisplay = 10; // cap display at Γ=10

    let svg = `<svg viewBox="0 0 ${steps} 100" preserveAspectRatio="none" class="w-full h-full">`;

    // grid lines
    for (let g = 1; g <= maxDisplay; g += 1) {
      const y = 100 - (g / maxDisplay) * 100;
      svg += `<line x1="0" y1="${y}" x2="${steps}" y2="${y}" stroke="#334155" stroke-width="0.3" />`;
    }

    // curve
    let path = 'M';
    for (let i = 0; i <= steps; i++) {
      const omega = i / steps;
      const g = gammaOmega(omega);
      const y = 100 - Math.min(g / maxDisplay, 1) * 100;
      path += `${i},${y} `;
    }
    svg += `<path d="${path}" fill="none" stroke="#ef4444" stroke-width="1.5" />`;

    // current position marker
    const cx = currentOmega * steps;
    const cy = 100 - Math.min(gammaOmega(currentOmega) / maxDisplay, 1) * 100;
    svg += `<circle cx="${cx}" cy="${cy}" r="3" fill="#f59e0b" stroke="#fff" stroke-width="0.5" />`;
    svg += `<line x1="${cx}" y1="0" x2="${cx}" y2="100" stroke="#f59e0b" stroke-width="0.5" stroke-dasharray="2,2" />`;

    // ω_trap marker
    const trapX = OMEGA_TRAP * steps;
    const trapY = 100 - Math.min(gammaOmega(OMEGA_TRAP) / maxDisplay, 1) * 100;
    svg += `<line x1="${trapX}" y1="0" x2="${trapX}" y2="100" stroke="#a855f7" stroke-width="0.5" stroke-dasharray="3,3" />`;
    svg += `<circle cx="${trapX}" cy="${trapY}" r="2" fill="#a855f7" />`;

    // regime boundaries
    const watchX = 0.038 * steps;
    const collapseX = 0.30 * steps;
    svg += `<line x1="${watchX}" y1="0" x2="${watchX}" y2="100" stroke="#22c55e" stroke-width="0.3" stroke-dasharray="4,4" />`;
    svg += `<line x1="${collapseX}" y1="0" x2="${collapseX}" y2="100" stroke="#ef4444" stroke-width="0.3" stroke-dasharray="4,4" />`;

    svg += '</svg>';

    // Y-axis labels
    chart.innerHTML = `
      <div class="absolute left-0 top-0 bottom-0 w-6 text-[9px] text-kernel-600 flex flex-col justify-between pr-1">
        <span>${maxDisplay}</span>
        <span>${maxDisplay / 2}</span>
        <span>0</span>
      </div>
      <div class="ml-6 h-full">${svg}</div>
      <div class="absolute text-[9px] text-amber-400 font-mono" style="left: ${cx / steps * 95 + 5}%; top: 4px;">
        Γ(${currentOmega.toFixed(3)}) = ${gammaOmega(currentOmega).toFixed(4)}
      </div>
      <div class="absolute text-[9px] text-purple-400 font-mono" style="left: ${OMEGA_TRAP * 95 + 5}%; bottom: 4px;">
        ω_trap = ${OMEGA_TRAP}
      </div>`;
  }

  // Cost anatomy cards
  function renderAnatomy() {
    const costs = [
      {
        name: 'Γ(ω) — Drift Cost',
        formula: 'Γ(ω) = ω^p / (1 − ω + ε)',
        desc: `Monotone increasing with a pole at ω = 1. The frozen exponent p = ${P_EXPONENT} makes ω_trap = ${OMEGA_TRAP} the Cardano root of x³ + x − 1 = 0. Beyond ω_trap, return cost exceeds capacity.`,
        color: 'border-red-700/50',
        samples: [0, 0.038, 0.15, 0.30, 0.50, OMEGA_TRAP, 0.80, 0.95].map(w => ({
          w, g: gammaOmega(w),
        })),
      },
      {
        name: 'D_C — Curvature Cost',
        formula: `D_C = α · C (α = ${ALPHA})`,
        desc: 'Linear cost in curvature. Measures coupling to uncontrolled degrees of freedom. At C = 0 (homogeneous), no curvature cost. At C = 1 (max heterogeneity), full penalty.',
        color: 'border-amber-700/50',
        samples: [0, 0.1, 0.2, 0.3, 0.5, 0.7, 0.9, 1.0].map(c => ({
          w: c, g: costCurvature(c),
        })),
      },
      {
        name: 'R·τ_R — Return Credit',
        formula: 'Credit = R · τ_R (0 if τ_R = ∞_rec)',
        desc: 'Only what returns earns credit. R measures credibility of re-entry; τ_R measures delay. Infinite delay (∞_rec) yields zero credit — the gesture gets nothing.',
        color: 'border-green-700/50',
        samples: [
          { w: 'R=0.1, τ=3', g: 0.3 },
          { w: 'R=0.5, τ=5', g: 2.5 },
          { w: 'R=1.0, τ=10', g: 10.0 },
          { w: 'R=0.3, τ=∞', g: 0 },
        ],
      },
    ];

    document.getElementById('cost-anatomy')!.innerHTML = costs.map(c => `
      <div class="bg-kernel-800 border ${c.color} rounded-lg p-4">
        <h3 class="text-sm font-bold text-kernel-200 mb-1">${c.name}</h3>
        <div class="text-xs font-mono text-kernel-400 mb-2">${c.formula}</div>
        <p class="text-xs text-kernel-500 mb-3">${c.desc}</p>
        <table class="w-full text-xs">
          <thead><tr class="text-kernel-500"><th class="text-left">Input</th><th class="text-right">Value</th></tr></thead>
          <tbody>
            ${c.samples.map(s => `
              <tr class="border-t border-kernel-700/50">
                <td class="text-kernel-400 py-0.5">${typeof s.w === 'number' ? s.w.toFixed(3) : s.w}</td>
                <td class="text-right font-mono text-kernel-300">${s.g > 1000 ? s.g.toExponential(2) : s.g.toFixed(4)}</td>
              </tr>`).join('')}
          </tbody>
        </table>
      </div>
    `).join('');
  }

  // Wire up
  Object.values(els).forEach(el => {
    if (el.type !== 'checkbox') el.addEventListener('input', update);
    else el.addEventListener('change', update);
  });

  renderAnatomy();
  update();
</script>
