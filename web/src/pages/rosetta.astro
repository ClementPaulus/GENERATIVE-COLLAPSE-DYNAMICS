---
import BaseLayout from '../layouts/BaseLayout.astro';
import RosettaTranslator from '../components/RosettaTranslator.astro';
const base = import.meta.env.BASE_URL;
const sections = ['about', 'translator', 'lenses', 'subpages', 'five-words'];
const lenses = [
  { name: 'Epistemology', drift: 'Change in belief/evidence', fidelity: 'Retained warrant', roughness: 'Inference friction', ret: 'Justified re-entry' },
  { name: 'Ontology', drift: 'State transition', fidelity: 'Conserved properties', roughness: 'Heterogeneity / seams', ret: 'Restored coherence' },
  { name: 'Phenomenology', drift: 'Perceived shift', fidelity: 'Stable features', roughness: 'Distress / bias / effort', ret: 'Coping / repair that holds' },
  { name: 'History', drift: 'Periodization', fidelity: 'Continuity / endurance', roughness: 'Rupture / confound', ret: 'Restitution / reconciliation' },
  { name: 'Policy', drift: 'Regime shift', fidelity: 'Mandate persistence', roughness: 'Friction / externality', ret: 'Reinstatement / acceptance' },
  { name: 'Semiotics', drift: 'Sign drift', fidelity: 'Ground persistence', roughness: 'Translation friction', ret: 'Interpretant closure' },
  { name: 'Physics', drift: 'Phase transition', fidelity: 'Conserved quantity', roughness: 'Coupling / noise', ret: 'Restorative equilibrium' },
  { name: 'Finance', drift: 'Regime change', fidelity: 'Portfolio persistence', roughness: 'Volatility / drawdown', ret: 'Recovery / reversion' },
  { name: 'Neuroscience', drift: 'State perturbation', fidelity: 'Baseline coherence', roughness: 'Neural noise / effort', ret: 'Homeostatic return' },
];
const subpages = [
  { slug: 'vocabulary', title: 'Five-Word Vocabulary', desc: 'The minimal prose interface: Drift, Fidelity, Roughness, Return, Integrity' },
  { slug: 'lexicon', title: 'Lexicon Latinum', desc: 'Latin canonical names and morphological seeds' },
  { slug: 'peirce', title: 'Peirce Correspondence', desc: 'GCD-Peirce semiotic mapping and convergence' },
  { slug: 'phenomena', title: 'Phenomena', desc: 'Observable phenomena through cross-lens analysis' },
  { slug: 'scenarios', title: 'Scenarios', desc: 'Multi-domain scenario translations' },
  { slug: 'spine', title: 'Discourse Spine', desc: 'The five-stop validation pipeline' },
];
---

<BaseLayout title="Rosetta Translation — GCD" description="Cross-lens translation of the five words across 9 disciplinary lenses.">
  <div class="max-w-5xl mx-auto">

    <!-- ═══════════ HERO ═══════════ -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-kernel-100 mb-2">Rosetta Translation</h1>
      <p class="text-kernel-400 text-lg italic">Significatio stabilis manet dum dialectus mutatur. — Meaning stays stable while dialect changes.</p>
      <p class="text-kernel-500 text-sm mt-2 max-w-3xl">
        The same five words &mdash; Drift, Fidelity, Roughness, Return, Integrity &mdash;
        translate across 9 disciplinary lenses. Different fields speak different dialects,
        but the underlying Contract, Closures, and Ledger keep meanings stable. The Rosetta
        is not a metaphor table &mdash; it is a mechanical translation of auditable structure.
      </p>
    </div>

    <!-- ═══════════ NAV ═══════════ -->
    <nav class="mb-8 flex flex-wrap gap-2">
      {sections.map(s => (
        <a href={`#${s}`} class="px-3 py-1.5 rounded-full text-xs font-medium
          bg-kernel-800/60 text-kernel-400 hover:text-kernel-200 hover:bg-kernel-700/60
          border border-kernel-700/40 transition no-underline">
          {s.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase())}
        </a>
      ))}
    </nav>

    <!-- ═══════════ §1: ABOUT ═══════════ -->
    <section id="about" class="mb-10">
      <h2 class="text-xl font-bold text-kernel-100 mb-4">How Translation Works</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="bg-kernel-900 border border-kernel-800 rounded-lg p-4">
          <h3 class="text-sm font-bold text-kernel-200 mb-2">Structural Stability</h3>
          <p class="text-xs text-kernel-400">
            Each word has an <strong>operational meaning</strong> tied to the frozen Contract
            and reconciled in the Integrity Ledger. When you translate "Drift" to an
            epistemological lens it becomes "change in belief/evidence" &mdash; but the Contract
            still defines <em>how much</em> drift is measured (&omega; = 1 &minus; F).
          </p>
        </div>
        <div class="bg-kernel-900 border border-kernel-800 rounded-lg p-4">
          <h3 class="text-sm font-bold text-kernel-200 mb-2">Integrity Is Never Asserted</h3>
          <p class="text-xs text-kernel-400">
            The fifth word &mdash; Integrity &mdash; is not translated per lens because it is
            always <em>derived</em>: read from the reconciled ledger and stance. I = e&#8342;
            gives unitless multiplicative comparability across seams, regardless of dialect.
          </p>
        </div>
        <div class="bg-kernel-900 border border-kernel-800 rounded-lg p-4">
          <h3 class="text-sm font-bold text-kernel-200 mb-2">Prose Interface</h3>
          <p class="text-xs text-kernel-400">
            Authors describe using the five words; the ledger, budget, and gates supply the
            audit. This split enables cross-domain reading (via the Rosetta) and multiplicative
            composition in I without forcing any field's jargon on another.
          </p>
        </div>
        <div class="bg-kernel-900 border border-kernel-800 rounded-lg p-4">
          <h3 class="text-sm font-bold text-kernel-200 mb-2">Four Steps to Use</h3>
          <p class="text-xs text-kernel-400">
            1. Bind to Contract &mdash; name the invariants constraining your claim.
            2. Write the four columns in prose using the chosen lens.
            3. Reconcile via ledger &mdash; compute residuals and derive Integrity.
            4. Publish receipts &mdash; provenance so readers can verify the seam.
          </p>
        </div>
      </div>
    </section>

    <!-- ═══════════ §2: TRANSLATOR ═══════════ -->
    <section id="translator" class="mb-10">
      <h2 class="text-xl font-bold text-kernel-100 mb-4">Interactive Translator</h2>
      <RosettaTranslator />
    </section>

    <!-- ═══════════ §3: LENSES ═══════════ -->
    <section id="lenses" class="mb-10">
      <h2 class="text-xl font-bold text-kernel-100 mb-4">9 Disciplinary Lenses</h2>
      <p class="text-sm text-kernel-400 mb-4">
        The same kernel output reads differently through each lens. Drift in physics is a
        phase transition; in policy it is a regime shift; in semiotics it is sign drift.
        The numbers are identical &mdash; the prose changes.
      </p>
      <div class="overflow-x-auto bg-kernel-900 border border-kernel-800 rounded-xl p-4">
        <table class="w-full text-xs">
          <thead>
            <tr class="text-kernel-500 border-b border-kernel-700">
              <th class="text-left p-2">Lens</th>
              <th class="text-left p-2">Drift</th>
              <th class="text-left p-2">Fidelity</th>
              <th class="text-left p-2">Roughness</th>
              <th class="text-left p-2">Return</th>
            </tr>
          </thead>
          <tbody class="text-kernel-400">
            {lenses.map(l => (
              <tr class="border-b border-kernel-800/50">
                <td class="p-2 font-medium text-kernel-200">{l.name}</td>
                <td class="p-2">{l.drift}</td>
                <td class="p-2">{l.fidelity}</td>
                <td class="p-2">{l.roughness}</td>
                <td class="p-2">{l.ret}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- ═══════════ §4: SUB-PAGES ═══════════ -->
    <section id="subpages" class="mb-10">
      <h2 class="text-xl font-bold text-kernel-100 mb-4">Deep Dives</h2>
      <p class="text-sm text-kernel-400 mb-4">
        Each aspect of the Rosetta system has its own dedicated page for detailed exploration.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {subpages.map(p => (
          <a href={`${base}rosetta/${p.slug}`}
             class="bg-kernel-900 border border-kernel-800 rounded-lg p-4 hover:border-kernel-600
                    transition group no-underline block">
            <h3 class="text-sm font-bold text-kernel-200 group-hover:text-kernel-100 mb-1">{p.title}</h3>
            <p class="text-xs text-kernel-500">{p.desc}</p>
            <span class="text-xs text-amber-500/70 mt-2 inline-block">&rarr; Explore</span>
          </a>
        ))}
      </div>
    </section>

    <!-- ═══════════ §5: FIVE WORDS ═══════════ -->
    <section id="five-words" class="mb-10">
      <h2 class="text-xl font-bold text-kernel-100 mb-4">The Five-Word Vocabulary</h2>
      <div class="grid grid-cols-1 sm:grid-cols-5 gap-3">
        <div class="bg-red-900/20 border border-red-800/40 rounded-lg p-3 text-center">
          <div class="text-lg font-bold text-red-400">Drift</div>
          <div class="text-[10px] text-kernel-500 italic mt-1">derivatio</div>
          <div class="text-xs text-kernel-400 mt-2">What moved</div>
        </div>
        <div class="bg-green-900/20 border border-green-800/40 rounded-lg p-3 text-center">
          <div class="text-lg font-bold text-green-400">Fidelity</div>
          <div class="text-[10px] text-kernel-500 italic mt-1">fidelitas</div>
          <div class="text-xs text-kernel-400 mt-2">What persisted</div>
        </div>
        <div class="bg-amber-900/20 border border-amber-800/40 rounded-lg p-3 text-center">
          <div class="text-lg font-bold text-amber-400">Roughness</div>
          <div class="text-[10px] text-kernel-500 italic mt-1">curvatura</div>
          <div class="text-xs text-kernel-400 mt-2">Where it was bumpy</div>
        </div>
        <div class="bg-blue-900/20 border border-blue-800/40 rounded-lg p-3 text-center">
          <div class="text-lg font-bold text-blue-400">Return</div>
          <div class="text-[10px] text-kernel-500 italic mt-1">reditus</div>
          <div class="text-xs text-kernel-400 mt-2">Credible re-entry</div>
        </div>
        <div class="bg-purple-900/20 border border-purple-800/40 rounded-lg p-3 text-center">
          <div class="text-lg font-bold text-purple-400">Integrity</div>
          <div class="text-[10px] text-kernel-500 italic mt-1">integritas</div>
          <div class="text-xs text-kernel-400 mt-2">Does it hang together</div>
        </div>
      </div>
      <p class="text-xs text-kernel-600 mt-3 text-center">
        Authors write in prose using these five words. The conservation budget
        &Delta;&kappa; = R&middot;&tau;&#7448; &minus; (D&#969; + D&#7580;) and
        interpretive density I &equiv; e&#8342; serve as the <strong>semantic warranty</strong>
        behind the prose.
      </p>
    </section>

    <!-- Footer -->
    <div class="text-center text-kernel-600 text-xs italic pb-8">
      Translatio inter campos. — Translation between fields.
    </div>
  </div>
</BaseLayout>
