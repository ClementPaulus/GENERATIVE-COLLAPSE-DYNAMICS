---
/**
 * Root index page — renders the domain network overview.
 * Content generated by: python -m umcp.hcg.builder --all
 */
import { getCollection, render } from 'astro:content';
import IndexLayout from '../layouts/IndexLayout.astro';

const indexEntries = await getCollection('networkIndex');
const entry = indexEntries[0];
const { Content } = await render(entry);
---

<IndexLayout frontmatter={entry.data}>
  <Content />
</IndexLayout>
